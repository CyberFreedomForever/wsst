[Unit]
Description=wsst — WebSocket Secure Tunnel (server / exit node)
Documentation=https://github.com/CyberFreedomForever/wsst
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nobody
Group=nogroup
AmbientCapabilities=CAP_NET_BIND_SERVICE

ExecStart=/usr/local/bin/wsst server \
  -server=wss://vps2.example.com/tunnel \
  -addr=:443 \
  -cert=/etc/letsencrypt/live/vps2.example.com/fullchain.pem \
  -key=/etc/letsencrypt/live/vps2.example.com/privkey.pem \
  -secret=${TUNNEL_SECRET}

EnvironmentFile=-/etc/wsst/server.env

Restart=always
RestartSec=5
LimitNOFILE=65535

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadOnlyPaths=/etc/letsencrypt

[Install]
WantedBy=multi-user.target
